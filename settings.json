{
  "permissions": {
    "allow": [
      "bash scripts/swebok-bootstrap.sh",
      "bash scripts/swebok-query.py",
      "bash scripts/adversarial-gate.sh",
      "bash scripts/validate-gates.sh",
      "bash scripts/validate-qa-gates.sh",
      "bash scripts/act-observe-verify.sh",
      "bash scripts/self-heal.sh",
      "bash scripts/browser-use-orchestrator.sh",
      "bash scripts/multiagent-launcher.sh",
      "bash scripts/skill-invoker.sh",
      "python3 scripts/swebok-query.py",
      "python3 scripts/generate-kg.py",
      "python3 scripts/intent-detector.py",
      "python3 scripts/generate-ka-index.py",
      "python3 scripts/generate-keyword-index.py",
      "python3 scripts/search-knowledge-base.py"
    ],
    "deny": []
  },
  "_hook_path_resolution_note": "All hook paths use ${HARNESS_DIR} expansion or relative-to-project. The distilled fork no longer references /home/doz/swebok-v4-harness/ — the 3 upstream scripts (phase-guard, bash-guard, auto-verify) are vendored at pre-tool-use/ and post-tool-use/ as of 2026-06-10 (closes Council finding #4 'settings.json fork coupling').",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          "bash ${HARNESS_DIR}/pre-tool-use/phase-guard.sh",
          "bash ${HARNESS_DIR}/pre-tool-use/token-counter.sh",
          "bash ${HARNESS_DIR}/pre-tool-use/phase-change-detector.sh"
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          "bash ${HARNESS_DIR}/pre-tool-use/bash-guard.sh",
          "bash ${HARNESS_DIR}/pre-tool-use/token-counter.sh"
        ]
      },
      {
        "matcher": "Skill|Task|Agent|WebFetch|WebSearch",
        "hooks": [
          "bash ${HARNESS_DIR}/pre-tool-use/phase-guard.sh",
          "bash ${HARNESS_DIR}/pre-tool-use/token-counter.sh"
        ]
      },
      {
        "matcher": "mcp__.*|Glob|Grep|LS|TodoWrite|NotebookRead|ExitPlanMode",
        "hooks": [
          "bash ${HARNESS_DIR}/pre-tool-use/phase-guard.sh",
          "bash ${HARNESS_DIR}/pre-tool-use/token-counter.sh"
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          "bash ${HARNESS_DIR}/post-tool-use/auto-verify.sh",
          "bash ${HARNESS_DIR}/post-tool-use/council-scheduler-hook.sh",
          "bash ${HARNESS_DIR}/post-tool-use/mini-council-hook.sh"
        ]
      },
      {
        "matcher": "Skill|Task|Agent|WebFetch|WebSearch",
        "hooks": ["bash ${HARNESS_DIR}/post-tool-use/auto-verify.sh"]
      },
      {
        "matcher": "Read",
        "hooks": ["bash ${HARNESS_DIR}/post-tool-use/auto-verify.sh"]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": ".*",
        "hooks": [
          "bash ${HARNESS_DIR}/pre-tool-use/auto-trigger-hook.sh"
        ]
      }
    ]
  },
  "mounts": {},
  "goals": {},
  "env": {
    "HARNESS_DIR": "${PWD}"
  }
}
